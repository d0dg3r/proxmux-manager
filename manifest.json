{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "PROXMUX",
  "version": "1.2.1",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "downloads",
    "downloads.open",
    "sidePanel",
    "cookies"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "store/proxmux_logo.png",
      "48": "store/proxmux_logo.png",
      "128": "store/proxmux_logo.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "store/proxmux_logo.png",
    "48": "store/proxmux_logo.png",
    "128": "store/proxmux_logo.png"
  }
}
